# Backend environment. Copy to backend/.env for native (non-Docker) runs.
# In Docker, these values are supplied by docker-compose.yml.

# Application
APP_ENV=development                 # development | staging | production
APP_NAME="Digital Leap GPOMS"
API_V1_PREFIX=/api

# Database — use the host-mapped port when running natively against Docker Postgres
DATABASE_URL=postgresql+psycopg://gpoms:gpoms_dev_password@localhost:5432/gpoms

# Security / JWT
SECRET_KEY=dev-insecure-change-me-please-generate-a-real-one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated origins allowed to call the API
BACKEND_CORS_ORIGINS=http://localhost:3000

# File storage
STORAGE_BACKEND=local               # local | s3 | supabase
STORAGE_LOCAL_DIR=./storage

# First-run bootstrap admin (seeded by scripts/seed.py — Module 1)
FIRST_ADMIN_EMAIL=admin@digitalleap.com
FIRST_ADMIN_PASSWORD=ChangeMe123!
