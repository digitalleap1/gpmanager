# Backend environment. Copy to backend/.env for native (non-Docker) runs.
# In Docker, these values are supplied by docker-compose.yml.

# Application
APP_ENV=development                 # development | staging | production
APP_NAME="Digital Leap GPOMS"
API_V1_PREFIX=/api

# Database — use the host-mapped port when running natively against Docker Postgres
DATABASE_URL=postgresql+psycopg://gpoms:gpoms_dev_password@localhost:5432/gpoms

# Security / JWT
SECRET_KEY=dev-insecure-change-me-please-generate-a-real-one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated origins allowed to call the API
BACKEND_CORS_ORIGINS=http://localhost:3000

# File storage
STORAGE_BACKEND=local               # local | s3 | supabase
STORAGE_LOCAL_DIR=./storage

# First-run bootstrap admin (seeded by scripts/seed.py — Module 1)
FIRST_ADMIN_EMAIL=admin@digitalleap.com
FIRST_ADMIN_PASSWORD=ChangeMe123!

# -----------------------------------------------------------------------------
# Integrations (OPTIONAL — all blank/off by default so the offline run is safe).
# Fill these in later to turn on email + Slack notifications, then set
# NOTIFICATIONS_ENABLED=true. Test from the app (admin) via POST /api/integrations/test.
# -----------------------------------------------------------------------------
# Email (SMTP). Thunderbird users: reuse the same server/port your mail client uses.
# e.g. mail.digitalleapmarketing.com : 587 (STARTTLS) with your full mailbox login.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                           # defaults to SMTP_USER when blank
SMTP_USE_TLS=true                    # STARTTLS on 587
SMTP_USE_SSL=false                   # set true (and SMTP_USE_TLS=false) for port 465
NOTIFY_EMAIL=                        # where alerts go, e.g. mukesh.kumar@digitalleapmarketing.com

# Slack incoming webhook (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=

# Master switch for event notifications (login / new user / etc.)
NOTIFICATIONS_ENABLED=false
