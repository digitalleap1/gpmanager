# Root environment — consumed by docker-compose.yml for variable substitution.
# Copy to .env and adjust. Never commit the real .env.

# ----- PostgreSQL -----
POSTGRES_USER=gpoms
POSTGRES_PASSWORD=gpoms_dev_password
POSTGRES_DB=gpoms
POSTGRES_PORT=5432

# ----- pgAdmin -----
PGADMIN_EMAIL=admin@digitalleap.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ----- Service ports -----
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ----- Backend secrets (override the insecure defaults) -----
SECRET_KEY=dev-insecure-change-me-please-generate-a-real-one
